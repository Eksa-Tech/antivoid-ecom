<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <div class="mb-12">
        <h1 class="text-5xl font-black text-slate-900 mb-4">Pilih Kategori</h1>
        <div class="h-2 w-32 bg-indigo-600 rounded-full"></div>
        <p class="text-slate-500 mt-6 max-w-xl text-lg">Telusuri berbagai kategori pilihan kami untuk menemukan produk yang sesuai dengan gaya dan kebutuhan Anda.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% Category.all.each_with_index do |category, index| %>
            <a href="/shop?category=<%= category.id %>" 
               class="group relative glass p-8 rounded-[40px] border border-white/60 hover-lift shadow-sm hover:shadow-2xl transition-all duration-500 animate__animated animate__fadeInUp"
               style="animation-delay: <%= index * 0.1 %>s">
                <div class="flex items-center justify-between relative z-10">
                    <div>
                        <div class="w-16 h-16 bg-white/80 rounded-2xl flex items-center justify-center mb-6 shadow-sm group-hover:bg-indigo-600 group-hover:text-white transition-all duration-500">
                            <i data-lucide="tag" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl font-black text-slate-900 mb-2 group-hover:text-indigo-600 transition"><%= category.name %></h3>
                        <% product_count = Product.count({category_id: category.id.to_s}) %>
                        <div class="flex items-center gap-2">
                             <span class="px-3 py-1 rounded-full bg-slate-100 text-slate-500 text-xs font-bold uppercase"><%= product_count %> Produk</span>
                             <% if product_count > 0 %>
                                <span class="flex h-2 w-2 rounded-full bg-indigo-500 animate-pulse"></span>
                             <% end %>
                        </div>
                    </div>
                    
                    <div class="w-12 h-12 rounded-full bg-slate-900 text-white flex items-center justify-center group-hover:bg-indigo-600 group-hover:scale-110 transition-all">
                        <i data-lucide="arrow-right" class="w-6 h-6"></i>
                    </div>
                </div>
                
                <!-- Decorative element -->
                <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-indigo-600/5 blur-3xl rounded-full group-hover:bg-indigo-600/20 transition-all"></div>
            </a>
        <% end %>
        
        <% if Category.all.empty? %>
            <div class="col-span-full glass rounded-[40px] py-32 text-center">
                <div class="bg-slate-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-400">
                    <i data-lucide="layers" class="w-10 h-10"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-800">Kategori Kosong</h3>
                <p class="text-slate-500 mt-2">Belum ada kategori yang ditambahkan saat ini.</p>
            </div>
        <% end %>
    </div>
</div>
