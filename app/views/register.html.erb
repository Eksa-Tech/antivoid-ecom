<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Akun - Antivoid Shop</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="icon" href="https://img.icons8.com/?size=100&id=44816&format=png&color=000000" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; background: #f8fafc; overflow-x: hidden; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.2); }
    </style>
</head>
<body class="relative min-h-screen">
    <!-- Animated Background Decor (Fixed so it doesn't move on scroll) -->
    <div class="fixed -top-24 -left-24 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl animate__animated animate__pulse animate__infinite -z-10"></div>
    <div class="fixed -bottom-24 -right-24 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl animate__animated animate__pulse animate__infinite animate__delay-2s -z-10"></div>

    <div class="min-h-screen flex items-center justify-center p-6 relative z-10">
        <div class="w-full max-w-md animate__animated animate__zoomIn">
            <div class="text-center mb-8">
                <a href="/" class="inline-flex items-center gap-2 mb-6">
                    <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200">
                        <i data-lucide="zap" class="text-white w-7 h-7"></i>
                    </div>
                    <span class="text-2xl font-black text-slate-900 tracking-tighter">ANTIVOID</span>
                </a>
                <h1 class="text-3xl font-black text-slate-900 mb-2">Buat Akun Baru</h1>
                <p class="text-slate-500">Bergabunglah dengan komunitas Antivoid</p>
            </div>

            <div class="glass p-8 rounded-[40px] shadow-2xl relative overflow-hidden">
                <% if defined?(error) && error %>
                    <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-6 text-sm font-bold flex items-center gap-2 animate__animated animate__shakeX">
                        <i data-lucide="alert-circle" class="w-5 h-5"></i> <%= error %>
                    </div>
                <% end %>

                <form action="/register" method="POST" class="space-y-5">
                    <div>
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Nama Lengkap</label>
                        <div class="relative">
                            <i data-lucide="user" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <input type="text" name="name" required placeholder="Nama Anda"
                                class="w-full bg-white/50 border border-slate-200 rounded-2xl pl-12 pr-6 py-4 outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition shadow-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Alamat Email</label>
                        <div class="relative">
                            <i data-lucide="mail" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <input type="email" name="email" required placeholder="email@contoh.com"
                                class="w-full bg-white/50 border border-slate-200 rounded-2xl pl-12 pr-6 py-4 outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition shadow-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Password</label>
                        <div class="relative">
                            <i data-lucide="lock" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <input type="password" name="password" required placeholder="••••••••"
                                class="w-full bg-white/50 border border-slate-200 rounded-2xl pl-12 pr-6 py-4 outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition shadow-sm">
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full bg-indigo-600 text-white py-4 rounded-2xl font-black text-lg shadow-xl shadow-indigo-100 hover:bg-slate-900 hover:shadow-none transition-all duration-300 flex items-center justify-center gap-3 active:scale-95">
                            Daftar Sekarang <i data-lucide="arrow-right" class="w-6 h-6"></i>
                        </button>
                    </div>
                </form>

                <div class="mt-8 pt-8 border-t border-slate-100 text-center">
                    <p class="text-slate-500 text-sm">Sudah punya akun? 
                        <a href="/login" class="text-indigo-600 font-bold hover:underline">Masuk di sini</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>lucide.createIcons();</script>
</body>
</html>
