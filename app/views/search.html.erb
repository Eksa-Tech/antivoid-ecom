<% 
    query = @req.params['q'] || ""
    products = Product.all({ name: { '$regex' => query, '$options' => 'i' } })
    
    @title = "Hasil Pencarian: #{query} - Antivoid Shop"
    @description = "Menampilkan hasil pencarian untuk '#{query}' di Antivoid Shop."
%>
<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <div class="mb-10">
        <h1 class="text-4xl font-black text-slate-900 mb-2 flex items-center gap-3">
            <i data-lucide="search" class="w-10 h-10 text-indigo-600"></i> Hasil Pencarian
        </h1>
        <p class="text-slate-500 font-medium italic">Menampilkan <%= products.size %> produk untuk "<%= query %>"</p>
        <div class="h-1.5 w-24 bg-indigo-600 rounded-full mt-4"></div>
    </div>

    <% if products.empty? %>
        <div class="glass p-12 rounded-[40px] text-center border border-white/60 shadow-xl">
            <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <i data-lucide="search-x" class="w-12 h-12 text-slate-400"></i>
            </div>
            <h2 class="text-2xl font-black text-slate-800 mb-2">Produk Tidak Ditemukan</h2>
            <p class="text-slate-500 mb-8 max-w-md mx-auto">Kami tidak dapat menemukan produk yang sesuai dengan kata kunci "<%= query %>". Coba gunakan kata kunci lain atau jelajahi kategori kami.</p>
            <a href="/shop" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-8 py-3 rounded-2xl font-bold hover:bg-slate-900 transition">
                Kembali ke Toko <i data-lucide="arrow-right" class="w-5 h-5"></i>
            </a>
        </div>
    <% else %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% products.each do |product| %>
                <div class="group relative bg-white/40 backdrop-blur-md border border-white/60 p-4 rounded-[32px] transition hover:shadow-2xl hover:shadow-indigo-100/50 hover:-translate-y-2">
                    <div class="aspect-square bg-slate-100 rounded-[24px] overflow-hidden mb-5 relative">
                        <img src="<%= product.image_url || 'https://via.placeholder.com/400' %>" 
                            alt="<%= product.name %>" 
                            class="w-full h-full object-center object-cover transition duration-500 group-hover:scale-110">
                        <div class="absolute inset-0 bg-indigo-600/0 group-hover:bg-indigo-600/10 transition-colors"></div>
                    </div>
                    
                    <div class="px-2">
                        <h3 class="text-lg font-black text-slate-800 line-clamp-1 mb-1 group-hover:text-indigo-600 transition">
                            <%= product.name %>
                        </h3>
                        <p class="text-indigo-600 font-black text-xl mb-4">
                            <%= ViewHelper.format_rupiah(product.price) %>
                        </p>
                        
                        <div class="flex items-center gap-2">
                            <a href="/product?id=<%= product.id %>" class="flex-grow bg-white border border-slate-200 text-slate-700 py-3 rounded-2xl font-bold text-sm text-center hover:bg-slate-50 transition active:scale-95">
                                Detail
                            </a>
                            <form action="/cart/add" method="POST" class="flex-shrink-0">
                                <input type="hidden" name="product_id" value="<%= product.id %>">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="bg-indigo-600 text-white p-3 rounded-2xl hover:bg-slate-900 transition active:scale-95 shadow-lg shadow-indigo-100">
                                    <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>
    <% end %>
</div>
