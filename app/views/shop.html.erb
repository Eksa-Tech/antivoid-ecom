<div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6 animate__animated animate__fadeIn">
        <div>
            <h1 class="text-4xl font-black text-slate-900 mb-2">Katalog Produk</h1>
            <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
        </div>
        
        <form action="/shop" method="GET" class="flex flex-wrap items-center gap-3 w-full md:w-auto">
            <div class="relative flex-grow md:w-80">
                <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                <input type="text" name="q" placeholder="Cari sesuatu yang keren..." value="<%= @req.params['q'] %>"
                    class="w-full glass bg-white/50 border border-white/60 rounded-2xl pl-12 pr-4 py-3.5 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition">
            </div>
            
            <select name="category" onchange="this.form.submit()" class="glass border border-white/60 rounded-2xl px-6 py-3.5 outline-none focus:ring-2 focus:ring-indigo-500 appearance-none bg-white/50">
                <option value="">Semua Kategori</option>
                <% Category.all.each do |cat| %>
                    <option value="<%= cat.id %>" <%= 'selected' if @req.params['category'] == cat.id.to_s %>><%= cat.name %></option>
                <% end %>
            </select>
            
            <button type="submit" class="bg-slate-900 text-white px-8 py-3.5 rounded-2xl font-bold shadow-lg shadow-slate-200 hover:bg-indigo-600 transition flex items-center gap-2">
                Filter
            </button>
        </form>
    </div>

    <% 
        filter = {}
        filter[:name] = /#{@req.params['q']}/i if @req.params['q'] && !@req.params['q'].empty?
        filter[:category_id] = @req.params['category'] if @req.params['category'] && !@req.params['category'].empty?
        
        per_page = 8
        current_page = (@req.params['page'] || 1).to_i
        current_page = 1 if current_page < 1
        
        total_products = Product.count(filter)
        total_pages = (total_products.to_f / per_page).ceil
        
        skip = (current_page - 1) * per_page
        products = Product.all(filter, limit: per_page, skip: skip)
        
        # Helper for query string
        def page_url(req, p)
            params = req.params.dup
            params['page'] = p
            "?" + params.map{|k,v| "#{k}=#{v}"}.join("&")
        end
    %>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% if products.empty? %>
            <div class="col-span-full glass rounded-[40px] py-32 text-center animate__animated animate__zoomIn">
                <div class="bg-slate-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="package-search" class="w-10 h-10 text-slate-400"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 mb-2">Produk Tidak Ditemukan</h3>
                <p class="text-slate-500">Coba gunakan kata kunci lain atau pilih kategori berbeda.</p>
            </div>
        <% end %>
        
        <% products.each_with_index do |product, index| %>
            <div class="group glass rounded-[32px] p-4 hover-lift border border-white/40 animate__animated animate__fadeInUp" 
                 style="animation-delay: <%= index * 0.1 %>s">
                <div class="relative aspect-[4/5] rounded-24 overflow-hidden mb-6 bg-slate-100 rounded-2xl">
                    <img src="<%= product.image_url || 'https://via.placeholder.com/400' %>" 
                        alt="<%= product.name %>" 
                        class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition"></div>
                </div>
                
                <div class="px-2 pb-2">
                    <div class="flex justify-between items-start mb-3">
                        <span class="text-[10px] font-bold text-indigo-600 uppercase tracking-widest bg-indigo-50 px-2 py-0.5 rounded-full mb-2 inline-block">
                            <%= Category.all.find{|c| c.id.to_s == product.category_id}&.name || 'Uncategorized' %>
                        </span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-800 line-clamp-1 group-hover:text-indigo-600 transition mb-3">
                        <a href="/product?id=<%= product.id %>"><%= product.name %></a>
                    </h3>
                    
                    <div class="flex items-center justify-between mt-auto">
                        <p class="text-2xl font-black text-slate-900"><%= ViewHelper.format_rupiah(product.price) %></p>
                        <form action="/cart/add" method="POST" class="scale-0 group-hover:scale-100 transition-transform origin-right duration-300">
                            <input type="hidden" name="product_id" value="<%= product.id %>">
                            <input type="hidden" name="quantity" value="1">
                            <button type="submit" class="bg-indigo-600 text-white p-3 rounded-2xl hover:bg-slate-900 transition shadow-lg shadow-indigo-100">
                                <i data-lucide="plus" class="w-5 h-5"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        <% end %>
    </div>

    <% if total_pages > 1 %>
        <div class="mt-16 flex justify-center items-center gap-3">
            <% if current_page > 1 %>
                <a href="<%= page_url(@req, current_page - 1) %>" 
                    class="glass border border-white/60 w-12 h-12 rounded-2xl flex items-center justify-center hover:bg-slate-900 hover:text-white transition shadow-sm">
                    <i data-lucide="chevron-left" class="w-5 h-5"></i>
                </a>
            <% end %>

            <% (1..total_pages).each do |p| %>
                <a href="<%= page_url(@req, p) %>" 
                    class="w-12 h-12 rounded-2xl flex items-center justify-center font-bold transition shadow-sm
                    <%= p == current_page ? 'bg-indigo-600 text-white shadow-indigo-100' : 'glass border border-white/60 hover:bg-white' %>">
                    <%= p %>
                </a>
            <% end %>

            <% if current_page < total_pages %>
                <a href="<%= page_url(@req, current_page + 1) %>" 
                    class="glass border border-white/60 w-12 h-12 rounded-2xl flex items-center justify-center hover:bg-slate-900 hover:text-white transition shadow-sm">
                    <i data-lucide="chevron-right" class="w-5 h-5"></i>
                </a>
            <% end %>
        </div>
    <% end %>
</div>
