<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Admin - Premium E-Commerce</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; background: #f8fafc; }
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
    </style>
</head>
<body class="bg-slate-50">
    <div class="min-h-screen flex items-center justify-center px-6 py-12 relative overflow-hidden">
        <!-- Decorative background elements -->
        <div class="absolute top-20 left-20 w-80 h-80 bg-indigo-600/10 blur-[120px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-20 right-20 w-80 h-80 bg-purple-600/10 blur-[120px] rounded-full animate-pulse"></div>

        <div class="glass w-full max-w-md p-10 rounded-[48px] border border-white/60 shadow-2xl relative z-10 animate__animated animate__zoomIn">
            <div class="text-center mb-10">
                <div class="glass w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm border border-white/60">
                    <i data-lucide="lock" class="w-8 h-8 text-indigo-600"></i>
                </div>
                <h1 class="text-3xl font-black text-slate-900 mb-2">Panel Admin</h1>
                <p class="text-slate-500 font-medium">Silakan masuk untuk mengelola toko Anda.</p>
            </div>

            <% if @error %>
                <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-8 flex items-center gap-3 border border-red-100 animate__animated animate__shakeX">
                    <i data-lucide="alert-circle" class="w-5 h-5"></i>
                    <p class="text-sm font-bold"><%= @error %></p>
                </div>
            <% end %>

            <form action="/login" method="POST" class="space-y-6">
                <div>
                    <label class="block text-xs font-black text-slate-500 mb-2 ml-1 uppercase tracking-widest">Email Address</label>
                    <div class="relative">
                        <i data-lucide="mail" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="email" name="email" required placeholder="admin@example.com"
                            class="w-full glass bg-white/50 border border-white/60 rounded-2xl pl-12 pr-4 py-4 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition shadow-sm">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-black text-slate-500 mb-2 ml-1 uppercase tracking-widest">Password</label>
                    <div class="relative">
                        <i data-lucide="key-round" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="password" name="password" required placeholder="••••••••"
                            class="w-full glass bg-white/50 border border-white/60 rounded-2xl pl-12 pr-4 py-4 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition shadow-sm">
                    </div>
                </div>

                <button type="submit" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-black text-lg shadow-xl shadow-slate-200 hover:bg-indigo-600 transition-all flex items-center justify-center gap-3 group">
                    Masuk Sekarang <i data-lucide="arrow-right" class="group-hover:translate-x-1 transition"></i>
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-slate-200/50 text-center">
                <a href="/" class="text-sm font-bold text-slate-400 hover:text-indigo-600 transition flex items-center justify-center gap-2">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali ke Toko
                </a>
            </div>
        </div>
    </div>
    
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
