<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @title || 'Antivoid Shop - Toko Online Premium & Modern' %></title>
    <meta name="description" content="<%= @description || 'Toko online premium dengan desain modern Glassmorphism. Temukan produk terbaik dengan harga kompetitif dan pengiriman cepat.' %>">
    <meta name="keywords" content="e-commerce, ruby, shop, premium, glassmorphism, belanja online, antivoid">
    <link rel="canonical" href="<%= @req.url %>">

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= @req.url %>">
    <meta property="og:title" content="<%= @title || 'Antivoid Shop' %>">
    <meta property="og:description" content="<%= @description || 'Toko online premium dengan desain modern Glassmorphism.' %>">
    <meta property="og:image" content="<%= @og_image || '/images/og-default.png' %>">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="<%= @req.url %>">
    <meta property="twitter:title" content="<%= @title || 'Antivoid Shop' %>">
    <meta property="twitter:description" content="<%= @description || 'Toko online premium dengan desain modern Glassmorphism.' %>">
    <meta property="twitter:image" content="<%= @og_image || '/images/og-default.png' %>">
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="icon" href="https://img.icons8.com/?size=100&id=44816&format=png&color=000000" type="image/png">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                    },
                    backdropBlur: {
                        xs: '2px',
                    }
                }
            }
        }
    </script>
    
    <style>
        body {
            background: radial-gradient(circle at top right, #fdfcfb 0%, #e2d1c3 100%);
            background-attachment: fixed;
        }
        .glass {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .glass-dark {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .loading-bar {
            height: 3px;
            background: linear-gradient(to right, #6366f1, #a855f7);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 9999;
            transition: width 0.3s ease;
            width: 0%;
        }
        .hover-lift {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .hover-lift:hover {
            transform: translateY(-5px);
        }
    </style>
</head>
<body class="text-slate-900 min-h-screen flex flex-col">
    <div id="loading" class="loading-bar"></div>

    <!-- Navigation -->
    <nav class="glass sticky top-4 mx-4 md:mx-8 mt-4 z-50 rounded-2xl shadow-lg border border-white/40">
        <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600 flex items-center gap-2">
                    <i data-lucide="zap" class="w-8 h-8 text-indigo-600"></i>
                    <span>Antivoid</span>
                </a>
                <div class="hidden md:flex items-center space-x-6">
                    <a href="/" class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition flex items-center gap-1">
                        <i data-lucide="home" class="w-4 h-4"></i> Beranda
                    </a>
                    <a href="/shop" class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition flex items-center gap-1">
                        <i data-lucide="shopping-bag" class="w-4 h-4"></i> Belanja
                    </a>
                    <a href="/categories" class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition flex items-center gap-1">
                        <i data-lucide="layers" class="w-4 h-4"></i> Kategori
                    </a>
                </div>
            </div>

            <div class="flex items-center gap-5">
                <a href="/cart" class="text-slate-600 hover:text-indigo-600 relative transition p-2 hover:bg-white/50 rounded-full">
                    <i data-lucide="shopping-cart" class="w-6 h-6"></i>
                    <% cart_count = (@req.session['cart'] || {}).values.sum %>
                    <% if cart_count > 0 %>
                        <span class="absolute top-0 right-0 bg-indigo-600 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full animate-bounce">
                            <%= cart_count %>
                        </span>
                    <% end %>
                </a>
                
                <div class="h-6 w-px bg-slate-300 mx-2 hidden md:block"></div>

                <div class="hidden md:flex items-center gap-4">
                    <% if AuthHelper.authenticated?(@req) %>
                        <a href="/admin" class="text-sm font-semibold text-slate-700 hover:text-indigo-600 transition flex items-center gap-1">
                            <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Admin
                        </a>
                        <a href="/logout" class="text-sm font-semibold text-red-500 hover:text-red-600 transition flex items-center gap-1">
                            <i data-lucide="log-out" class="w-4 h-4"></i> Keluar
                        </a>
                    <% end %>
                </div>

                <button id="mobile-menu-btn" class="md:hidden text-slate-600 p-2 hover:bg-white/50 rounded-full transition">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="hidden md:hidden glass border-t border-white/40 animate__animated animate__fadeIn">
            <div class="p-6 space-y-4">
                <a href="/" class="flex items-center gap-3 p-4 rounded-xl hover:bg-white/40 transition">
                    <i data-lucide="home" class="w-5 h-5 text-indigo-600"></i>
                    <span class="font-bold">Beranda</span>
                </a>
                <a href="/shop" class="flex items-center gap-3 p-4 rounded-xl hover:bg-white/40 transition">
                    <i data-lucide="shopping-bag" class="w-5 h-5 text-indigo-600"></i>
                    <span class="font-bold">Belanja</span>
                </a>
                <a href="/categories" class="flex items-center gap-3 p-4 rounded-xl hover:bg-white/40 transition">
                    <i data-lucide="layers" class="w-5 h-5 text-indigo-600"></i>
                    <span class="font-bold">Kategori</span>
                </a>
                
                <div class="h-px bg-white/40 my-4"></div>
                
                <% if AuthHelper.authenticated?(@req) %>
                    <a href="/admin" class="flex items-center gap-3 p-4 rounded-xl hover:bg-white/40 transition">
                        <i data-lucide="layout-dashboard" class="w-5 h-5 text-indigo-600"></i>
                        <span class="font-bold">Panel Admin</span>
                    </a>
                    <a href="/logout" class="flex items-center gap-3 p-4 rounded-xl text-red-500 hover:bg-red-50 transition">
                        <i data-lucide="log-out" class="w-5 h-5"></i>
                        <span class="font-bold">Keluar</span>
                    </a>
                <% end %>
            </div>
        </div>
    </nav>

    <script>
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        if(btn && menu) {
            btn.addEventListener('click', () => {
                menu.classList.toggle('hidden');
            });
        }
    </script>

    <main class="flex-grow animate__animated animate__fadeIn">
        <%= main_content %>
    </main>

    <footer class="mt-20 glass rounded-t-3xl border-t border-white/40">
        <div class="max-w-7xl mx-auto py-16 px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
                <div class="col-span-1 md:col-span-2">
                    <a href="/" class="text-2xl font-bold text-indigo-600 flex items-center gap-2 mb-4">
                        <i data-lucide="zap" class="w-8 h-8"></i> Antivoid Shop
                    </a>
                    <p class="text-slate-500 max-w-sm">Toko online premium untuk kebutuhan gaya hidup modern Anda. Kualitas terbaik, pengiriman cepat.</p>
                </div>
                <div>
                    <h4 class="font-bold text-slate-900 mb-4">Navigasi</h4>
                    <ul class="space-y-2 text-slate-500 text-sm">
                        <li><a href="/" class="hover:text-indigo-600 transition">Beranda</a></li>
                        <li><a href="/shop" class="hover:text-indigo-600 transition">Belanja</a></li>
                        <li><a href="/categories" class="hover:text-indigo-600 transition">Kategori</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold text-slate-900 mb-4">Bantuan</h4>
                    <ul class="space-y-2 text-slate-500 text-sm">
                        <li><a href="/about" class="hover:text-indigo-600 transition">Tentang Kami</a></li>
                        <li><a href="/contact" class="hover:text-indigo-600 transition">Kontak</a></li>
                        <li><a href="/terms" class="hover:text-indigo-600 transition">Syarat & Ketentuan</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-slate-200 mt-12 pt-8 text-center text-slate-400 text-xs">
                <p>&copy; 2026 Antivoid E-Commerce Premium. Seluruh Hak Cipta Dilindungi.</p>
            </div>
        </div>
    </footer>

    <script>
        // Init Lucide Icons
        lucide.createIcons();

        // Loading bar simulation
        window.addEventListener('load', () => {
            const bar = document.getElementById('loading');
            bar.style.width = '100%';
            setTimeout(() => {
                bar.style.opacity = '0';
            }, 300);
        });

        // Add loading effect on link clicks
        document.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', (e) => {
                if(link.href && link.href.startsWith(window.location.origin)) {
                    document.getElementById('loading').style.width = '30%';
                    document.getElementById('loading').style.opacity = '1';
                }
            });
        });
    </script>
</body>
</html>
