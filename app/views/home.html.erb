<% 
    @title = "Antivoid Shop - Toko Online Premium & Modern"
    @description = "Selamat datang di Antivoid Shop. Temukan koleksi produk gaya hidup premium dengan desain modern Glassmorphism."
%>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<style>
    .swiper-pagination-bullet-active { background: #6366f1 !important; }
</style>

<% active_banners = Banner.active %>

<div class="relative overflow-hidden pl-4 pr-4 pt-8 pb-10">
    <% if active_banners.empty? %>
        <!-- Fallback Hero (Static) if no banners -->
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="animate__animated animate__fadeInLeft">
                <span class="inline-block px-4 py-1.5 rounded-full glass bg-indigo-50 text-indigo-600 text-sm font-bold mb-6 border border-indigo-100 uppercase tracking-widest">Koleksi Baru 2026</span>
                <h1 class="text-5xl md:text-7xl font-extrabold text-slate-900 leading-[1.1] mb-8">
                    Upgrade Gaya Hidup <br/>
                    <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">Masa Depan Anda</span>
                </h1>
                <p class="text-xl text-slate-500 mb-10 max-w-lg leading-relaxed">
                    Temukan koleksi produk pilihan berkualitas tinggi dengan desain modern dan performa terbaik di Antivoid Shop.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="/shop" class="group bg-indigo-600 text-white px-8 py-4 rounded-2xl font-bold text-lg shadow-xl shadow-indigo-200 hover:bg-indigo-700 transition flex items-center gap-2">
                        Belanja Sekarang <i data-lucide="arrow-right" class="group-hover:translate-x-1 transition"></i>
                    </a>
                </div>
            </div>
            <div class="relative hidden md:block">
                <div class="glass p-4 rounded-[40px] shadow-2xl border border-white/60">
                    <img class="rounded-[30px] w-full h-[500px] object-cover" 
                        src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80">
                </div>
            </div>
        </div>
    <% else %>
        <!-- Swiper Slider -->
        <div class="swiper mainSwiper px-6">
            <div class="swiper-wrapper">
                <% active_banners.each do |banner| %>
                    <% banner_url = banner.link.to_s.match?(/^(http|\/)/) ? banner.link : (banner.link.to_s.empty? ? '#' : "http://#{banner.link}") %>
                    <div class="swiper-slide pt-4 pb-12">
                        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center min-h-[400px]">
                            <div class="animate__animated animate__fadeInLeft py-4 lg:py-10">
                                <h2 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-slate-900 leading-[1.1] mb-4 lg:mb-6">
                                    <%= banner.title %>
                                </h2>
                                <p class="text-xl lg:text-2xl text-indigo-600 font-black mb-8 lg:mb-10 tracking-wide uppercase">
                                    <%= banner.subtitle %>
                                </p>
                                <a href="<%= banner_url %>" class="inline-flex items-center gap-2 bg-slate-900 text-white px-8 py-4 lg:px-10 lg:py-5 rounded-2xl font-black text-md lg:text-lg hover:bg-indigo-600 transition shadow-2xl">
                                    Lihat Promo <i data-lucide="external-link" class="w-5 h-5 lg:w-6 lg:h-6"></i>
                                </a>
                            </div>
                            <div class="relative py-4 lg:py-10">
                                <a href="<%= banner_url %>" class="block glass p-2 lg:p-4 rounded-[30px] lg:rounded-[40px] shadow-2xl border border-white/60 overflow-hidden transform hover:scale-[1.02] transition-transform duration-500">
                                    <img class="rounded-[20px] lg:rounded-[30px] w-full h-[300px] lg:h-[450px] object-cover shadow-inner" src="<%= banner.image_url %>">
                                </a>
                            </div>
                        </div>
                    </div>
                <% end %>
            </div>
            <div class="swiper-pagination !-bottom-1"></div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                new Swiper(".mainSwiper", {
                    autoplay: { delay: 5000, disableOnInteraction: false },
                    pagination: { el: ".swiper-pagination", clickable: true },
                    speed: 1000,
                    loop: true,
                    effect: 'fade',
                    fadeEffect: { crossFade: true }
                });
            });
        </script>
    <% end %>
</div>

<!-- Featured Products Grid -->
<div class="max-w-7xl mx-auto px-6 py-20">
    <div class="flex justify-between items-end mb-12">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-2">Produk Unggulan</h2>
            <div class="h-1.5 w-20 bg-indigo-600 rounded-full"></div>
        </div>
        <a href="/shop" class="text-indigo-600 font-bold flex items-center gap-1 hover:gap-2 transition-all">
            Lihat Semua <i data-lucide="chevron-right" class="w-5 h-5"></i>
        </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% Product.all.take(4).each do |product| %>
            <div class="group glass rounded-3xl p-4 hover-lift border border-white/40 shadow-sm transition-all hover:shadow-xl hover:shadow-indigo-100 relative">
                <a href="/product?id=<%= product.id %>" class="absolute inset-0 z-0"></a>
                <div class="relative aspect-square rounded-2xl overflow-hidden mb-6 bg-slate-100">
                    <img src="<%= product.image_url || 'https://via.placeholder.com/400' %>" 
                        alt="<%= product.name %>" 
                        class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                    <div class="absolute top-4 right-4 animate-pulse">
                        <span class="glass-dark text-white text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-widest bg-indigo-600/50">Populer</span>
                    </div>
                </div>
                <div class="px-2">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-slate-800 line-clamp-1 group-hover:text-indigo-600 transition"><%= product.name %></h3>
                    </div>
                    <div class="flex items-center justify-between relative z-10">
                        <p class="text-2xl font-black text-indigo-600 pointer-events-none"><%= ViewHelper.format_rupiah(product.price) %></p>
                        <a href="/product?id=<%= product.id %>" class="bg-white border border-slate-200 text-slate-700 p-2 rounded-xl hover:bg-indigo-600 hover:text-white hover:border-indigo-600 transition shadow-sm cursor-pointer">
                            <i data-lucide="eye" class="w-5 h-5"></i>
                        </a>
                    </div>
                </div>
            </div>
        <% end %>
    </div>
</div>

<!-- Benefits Section -->
<div class="max-w-7xl mx-auto px-6 py-20 mb-20 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="glass p-8 rounded-[32px] border border-white/60">
        <div class="w-14 h-14 bg-indigo-100 text-indigo-600 rounded-2xl flex items-center justify-center mb-6">
            <i data-lucide="truck" class="w-8 h-8"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Pengiriman Cepat</h3>
        <p class="text-slate-500">Nikmati layanan pengiriman prioritas yang menjangkau seluruh wilayah dalam waktu singkat.</p>
    </div>
    <div class="glass p-8 rounded-[32px] border border-white/60">
        <div class="w-14 h-14 bg-purple-100 text-purple-600 rounded-2xl flex items-center justify-center mb-6">
            <i data-lucide="shield-check" class="w-8 h-8"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Garansi Aman</h3>
        <p class="text-slate-500">Setiap produk kami dijamin keasliannya dan dilindungi garansi resmi untuk keamanan Anda.</p>
    </div>
    <div class="glass p-8 rounded-[32px] border border-white/60">
        <div class="w-14 h-14 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mb-6">
            <i data-lucide="headset" class="w-8 h-8"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Layanan 24/7</h3>
        <p class="text-slate-500">Tim bantuan kami siap melayani pertanyaan Anda kapan saja melalui live chat dan email.</p>
    </div>
</div>
