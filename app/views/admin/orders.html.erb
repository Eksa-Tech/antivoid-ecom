<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <div class="mb-10">
        <a href="/admin" class="text-sm font-bold text-slate-400 hover:text-indigo-600 transition flex items-center gap-2 mb-4">
            <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Kembali ke Dashboard
        </a>
        <div class="flex flex-wrap justify-between items-end gap-4">
            <div>
                <h1 class="text-4xl font-black text-slate-900 mb-2">Kelola Pesanan</h1>
                <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
            </div>
            <a href="/admin/orders/export" class="bg-emerald-600 text-white px-6 py-3 rounded-2xl font-bold flex items-center gap-2 hover:bg-slate-900 transition shadow-lg shadow-emerald-100">
                <i data-lucide="download" class="w-5 h-5"></i> Ekspor CSV
            </a>
        </div>
    </div>

    <div class="glass rounded-[40px] overflow-hidden border border-white/60 shadow-xl bg-white/30">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-900/5 text-slate-500 border-b border-white/40">
                        <th class="px-8 py-5 text-xs font-black uppercase tracking-widest">ID Pesanan</th>
                        <th class="px-8 py-5 text-xs font-black uppercase tracking-widest">Pelanggan</th>
                        <th class="px-8 py-5 text-xs font-black uppercase tracking-widest text-center">Total</th>
                        <th class="px-8 py-5 text-xs font-black uppercase tracking-widest text-center">Status</th>
                        <th class="px-8 py-5 text-xs font-black uppercase tracking-widest text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/40 text-sm">
                    <% 
                        per_page = 10
                        current_page = (@req.params['page'] || 1).to_i
                        total_orders = Order.count({})
                        total_pages = (total_orders.to_f / per_page).ceil
                        skip = (current_page - 1) * per_page
                        orders = Order.all({}, limit: per_page, skip: skip)
                        
                        def page_url(req, p)
                            params = req.params.dup
                            params['page'] = p
                            "?" + params.map{|k,v| "#{k}=#{v}"}.join("&")
                        end
                    %>
                    <% orders.each do |order| %>
                    <tr class="hover:bg-white/50 transition">
                        <td class="px-8 py-5">
                            <span class="font-mono text-xs font-bold text-indigo-600">#<%= order.id.to_s[-8..] %></span>
                        </td>
                        <td class="px-8 py-5">
                            <h4 class="font-bold text-slate-900"><%= order.customer_name %></h4>
                            <p class="text-xs text-slate-400 font-medium"><%= order.contact %></p>
                        </td>
                        <td class="px-8 py-5 text-center font-black text-slate-900"><%= ViewHelper.format_rupiah(order.total_price) %></td>
                        <td class="px-8 py-5 text-center">
                            <% 
                                color = case order.status
                                        when 'Pending' then 'bg-orange-100 text-orange-600'
                                        when 'Paid' then 'bg-blue-100 text-blue-600'
                                        when 'Shipped' then 'bg-purple-100 text-purple-600'
                                        when 'Delivered' then 'bg-green-100 text-green-600'
                                        else 'bg-slate-100 text-slate-600'
                                        end
                            %>
                            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase <%= color %>">
                                <%= order.status %>
                            </span>
                        </td>
                        <td class="px-8 py-5 text-center flex items-center justify-center gap-2">
                            <a href="/admin/orders/view?id=<%= order.id %>" class="bg-indigo-50 text-indigo-600 p-2 rounded-xl hover:bg-indigo-600 hover:text-white transition shadow-sm border border-indigo-100">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                            </a>
                            <form action="/admin/orders/update" method="POST" class="flex items-center justify-center gap-2">
                                <input type="hidden" name="id" value="<%= order.id %>">
                                <div class="relative">
                                    <select name="status" class="glass bg-white/50 border border-white/40 rounded-xl px-3 py-2 text-[10px] font-bold outline-none appearance-none pr-8">
                                        <option value="Pending" <%= 'selected' if order.status == 'Pending' %>>Pending</option>
                                        <option value="Paid" <%= 'selected' if order.status == 'Paid' %>>Dibayar</option>
                                        <option value="Shipped" <%= 'selected' if order.status == 'Shipped' %>>Dikirim</option>
                                        <option value="Delivered" <%= 'selected' if order.status == 'Delivered' %>>Selesai</option>
                                    </select>
                                    <i data-lucide="chevron-down" class="absolute right-2 top-1/2 -translate-y-1/2 w-3 h-3 text-slate-400"></i>
                                </div>
                                <div class="relative flex items-center">
                                    <input type="text" name="resi" id="resi-<%= order.id %>" value="<%= order.resi %>" placeholder="No. Resi"
                                        class="glass bg-white/50 border border-white/40 rounded-l-xl px-3 py-2 text-[10px] font-bold outline-none w-24">
                                    <button type="button" onclick="const input = document.getElementById('resi-<%= order.id %>'); input.value = 'AVD-' + Math.random().toString(36).substring(2, 10).toUpperCase();"
                                        class="bg-slate-100 border-y border-r border-white/40 text-slate-400 p-2 rounded-r-xl hover:text-indigo-600 transition">
                                        <i data-lucide="refresh-cw" class="w-3 h-3"></i>
                                    </button>
                                </div>
                                <button type="submit" class="bg-indigo-600 text-white p-2 rounded-xl hover:bg-slate-900 transition shadow-sm">
                                    <i data-lucide="save" class="w-4 h-4"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% end %>
                    <% if orders.empty? %>
                        <tr>
                            <td colspan="5" class="px-8 py-20 text-center text-slate-400 font-medium italic">Belum ada pesanan masuk.</td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>

    <% if total_pages > 1 %>
        <div class="mt-10 flex justify-center items-center gap-2">
            <% if current_page > 1 %>
                <a href="<%= page_url(@req, current_page - 1) %>" 
                    class="glass border border-white/60 w-10 h-10 rounded-xl flex items-center justify-center hover:bg-slate-900 hover:text-white transition shadow-sm text-xs">
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </a>
            <% end %>

            <% (1..total_pages).each do |p| %>
                <a href="<%= page_url(@req, p) %>" 
                    class="w-10 h-10 rounded-xl flex items-center justify-center font-bold text-xs transition shadow-sm
                    <%= p == current_page ? 'bg-indigo-600 text-white shadow-indigo-100' : 'glass border border-white/60 hover:bg-white' %>">
                    <%= p %>
                </a>
            <% end %>

            <% if current_page < total_pages %>
                <a href="<%= page_url(@req, current_page + 1) %>" 
                    class="glass border border-white/60 w-10 h-10 rounded-xl flex items-center justify-center hover:bg-slate-900 hover:text-white transition shadow-sm text-xs">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
            <% end %>
        </div>
    <% end %>
</div>
