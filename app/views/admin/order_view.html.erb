<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <div class="mb-10 flex items-center justify-between">
        <div>
            <a href="/admin/orders" class="text-sm font-bold text-slate-400 hover:text-indigo-600 transition flex items-center gap-2 mb-4">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali ke Daftar Pesanan
            </a>
            <h1 class="text-4xl font-black text-slate-900 mb-2">Detail Pesanan <span class="text-indigo-600">#<%= @order.id.to_s[-8..] %></span></h1>
            <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
        </div>
        
        <div class="flex items-center gap-3">
             <% 
                color = case @order.status
                        when 'Pending' then 'bg-orange-100 text-orange-600 border-orange-200'
                        when 'Paid' then 'bg-blue-100 text-blue-600 border-blue-200'
                        when 'Shipped' then 'bg-purple-100 text-purple-600 border-purple-200'
                        when 'Delivered' then 'bg-green-100 text-green-600 border-green-200'
                        else 'bg-slate-100 text-slate-600 border-slate-200'
                        end
            %>
            <span class="px-6 py-2 rounded-2xl text-xs font-black uppercase border <%= color %>">
                <%= @order.status %>
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Main Content: Order Items -->
        <div class="lg:col-span-2 space-y-10">
            <!-- Order Items List -->
            <div class="glass rounded-[40px] border border-white/60 shadow-xl overflow-hidden bg-white/30 p-10">
                <h3 class="text-xl font-bold text-slate-900 mb-8 flex items-center gap-2">
                    <i data-lucide="package" class="w-6 h-6 text-indigo-600"></i> Daftar Produk
                </h3>
                
                <div class="divide-y divide-white/40">
                    <% @order.items.each do |item| %>
                        <div class="py-6 flex items-center gap-6">
                            <div class="w-20 h-20 bg-slate-100 rounded-2xl overflow-hidden border border-white/40 shadow-sm flex-shrink-0">
                                <img src="<%= item[:product].image_url || 'https://via.placeholder.com/100' %>" 
                                     class="w-full h-full object-cover">
                            </div>
                            <div class="flex-grow">
                                <h4 class="font-bold text-slate-900"><%= item[:product].name %></h4>
                                <p class="text-xs text-slate-400 font-bold uppercase tracking-wider">
                                    <%= item[:quantity] %> Item x <%= ViewHelper.format_rupiah(item[:product].price) %>
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="font-black text-slate-900"><%= ViewHelper.format_rupiah(item[:product].price * item[:quantity]) %></p>
                            </div>
                        </div>
                    <% end %>
                </div>

                <div class="mt-10 pt-10 border-t border-white/60">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-slate-500 font-bold uppercase text-xs tracking-widest">Subtotal</span>
                        <span class="font-bold text-slate-900"><%= ViewHelper.format_rupiah(@order.total_price) %></span>
                    </div>
                    <div class="flex justify-between items-center mb-6">
                        <span class="text-slate-500 font-bold uppercase text-xs tracking-widest">Pengiriman</span>
                        <span class="font-bold text-green-600 uppercase text-xs">Gratis Ongkir</span>
                    </div>
                    <div class="flex justify-between items-center bg-indigo-50/50 p-6 rounded-3xl border border-indigo-100">
                        <span class="text-slate-900 font-black text-xl">Total Pembayaran</span>
                        <span class="text-3xl font-black text-indigo-600"><%= ViewHelper.format_rupiah(@order.total_price) %></span>
                    </div>
                </div>
            </div>
            
            <!-- Update Status Section -->
            <div class="glass rounded-[40px] border border-white/60 shadow-xl p-10 bg-indigo-900 text-white relative overflow-hidden">
                <div class="absolute -bottom-10 -right-10 w-48 h-48 bg-white/10 blur-3xl rounded-full"></div>
                <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
                    <i data-lucide="refresh-ccw" class="w-6 h-6 text-indigo-400"></i> Perbarui Status
                </h3>
                <form action="/admin/orders/update" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
                    <input type="hidden" name="id" value="<%= @order.id %>">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-indigo-300 mb-3 ml-1">Status Pengiriman</label>
                        <div class="relative">
                            <select name="status" class="w-full bg-white/10 border border-white/20 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-white focus:bg-white focus:text-slate-900 outline-none transition font-bold appearance-none">
                                <option value="Pending" <%= 'selected' if @order.status == 'Pending' %>>Pending (Menunggu)</option>
                                <option value="Paid" <%= 'selected' if @order.status == 'Paid' %>>Dibayar (Proses Paking)</option>
                                <option value="Shipped" <%= 'selected' if @order.status == 'Shipped' %>>Dikirim (On the Way)</option>
                                <option value="Delivered" <%= 'selected' if @order.status == 'Delivered' %>>Selesai (Diterima)</option>
                            </select>
                            <i data-lucide="chevron-down" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 opacity-50"></i>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-3 ml-1">
                            <label class="block text-[10px] font-black uppercase tracking-widest text-indigo-300">Nomor Resi</label>
                            <button type="button" onclick="document.getElementById('resi-input').value = 'AVD-' + Math.random().toString(36).substring(2, 12).toUpperCase();"
                                class="text-[10px] font-black uppercase tracking-widest text-indigo-400 hover:text-white transition flex items-center gap-1">
                                <i data-lucide="sparkles" class="w-3 h-3"></i> Buat Otomatis
                            </button>
                        </div>
                        <input type="text" name="resi" id="resi-input" value="<%= @order.resi %>" placeholder="Masukkan nomor resi..."
                            class="w-full bg-white/10 border border-white/20 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-white focus:bg-white focus:text-slate-900 outline-none transition font-bold">
                    </div>
                    <div class="md:col-span-2">
                        <button type="submit" class="w-full bg-white text-indigo-600 py-4 rounded-2xl font-black shadow-lg hover:bg-slate-900 hover:text-white transition-all transform hover:scale-[1.02]">
                            Simpan Perubahan
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Sidebar: Customer Info -->
        <div class="space-y-10">
            <div class="glass rounded-[40px] border border-white/60 shadow-xl p-8 bg-white/50">
                <h3 class="text-xl font-bold text-slate-900 mb-8 flex items-center gap-2">
                    <i data-lucide="user" class="w-6 h-6 text-indigo-600"></i> Informasi Pelanggan
                </h3>
                
                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="user-check" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Nama Lengkap</p>
                            <p class="font-bold text-slate-900"><%= @order.customer_name %></p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="phone" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Kontak / WhatsApp</p>
                            <p class="font-bold text-slate-900"><%= @order.contact %></p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="map-pin" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Alamat Pengiriman</p>
                            <p class="font-bold text-slate-900 leading-relaxed"><%= @order.address %></p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-orange-100 text-orange-600 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i data-lucide="clock" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Waktu Pesanan</p>
                            <p class="font-bold text-slate-900"><%= @order.created_at || 'Baru Saja' %></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Shipping Preview -->
            <% if @order.resi && !@order.resi.empty? %>
                <div class="glass rounded-[40px] border border-white/60 shadow-xl p-8 bg-green-50/50 border-green-200">
                    <h3 class="text-xl font-bold text-green-900 mb-4 flex items-center gap-2">
                        <i data-lucide="truck" class="w-6 h-6"></i> Informasi Resi
                    </h3>
                    <div class="bg-white p-4 rounded-2xl border border-green-100 shadow-sm">
                        <p class="text-[10px] font-black text-green-600 uppercase tracking-widest mb-2">No. Resi Pengiriman</p>
                        <p class="font-black text-2xl text-slate-900 tracking-wider font-mono"><%= @order.resi %></p>
                    </div>
                </div>
            <% end %>
        </div>
    </div>
</div>
