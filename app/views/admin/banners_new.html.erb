<div class="max-w-4xl mx-auto px-6 pt-20 pb-12 animate__animated animate__fadeIn">
    <div class="mb-10 flex items-center justify-between">
        <div>
            <a href="/admin/banners" class="text-sm font-bold text-slate-400 hover:text-indigo-600 transition flex items-center gap-2 mb-4">
                <i data-lucide="image" class="w-4 h-4"></i> Kembali ke Daftar Banner
            </a>
            <h1 class="text-4xl font-black text-slate-900 mb-2">Tambah Banner Baru</h1>
            <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
        </div>
    </div>

    <div class="glass rounded-[40px] border border-white/60 shadow-2xl p-10">
        <form action="/admin/banners/add" method="POST" enctype="multipart/form-data" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Judul Utama</label>
                    <input type="text" name="title" required placeholder="Contoh: Diskon Akhir Tahun" 
                        class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-indigo-500 transition shadow-sm">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Subjudul</label>
                    <input type="text" name="subtitle" required placeholder="Contoh: S/D 70%" 
                        class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-indigo-500 transition shadow-sm">
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Link Tujuan</label>
                    <input type="text" name="link" required placeholder="Contoh: /shop" 
                        class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 outline-none focus:ring-2 focus:ring-indigo-500 transition shadow-sm">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 ml-1">Gambar Banner</label>
                    <input type="file" name="image" required 
                        class="w-full text-sm text-slate-500 file:mr-4 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-xs file:font-black file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 cursor-pointer">
                </div>
            </div>

            <div class="flex items-center gap-3 bg-white/40 p-4 rounded-2xl border border-white/60 w-fit">
                <input type="checkbox" name="active" id="active" checked 
                    class="w-5 h-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                <label for="active" class="text-sm font-bold text-slate-700">Aktifkan Banner Sekarang</label>
            </div>

            <div class="pt-4">
                <button type="submit" class="w-full bg-indigo-600 text-white py-5 rounded-2xl font-black text-lg hover:bg-slate-900 transition-all shadow-xl shadow-indigo-100">
                    Simpan Banner
                </button>
            </div>
        </form>
    </div>
</div>
