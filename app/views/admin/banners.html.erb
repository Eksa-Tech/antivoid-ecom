<div class="max-w-7xl mx-auto px-6 pt-24 pb-12 animate__animated animate__fadeIn">
    <div class="mb-10 flex justify-between items-end">
        <div>
            <a href="/admin" class="text-sm font-bold text-slate-400 hover:text-indigo-600 transition flex items-center gap-2 mb-4">
                <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Kembali ke Dashboard
            </a>
            <h1 class="text-4xl font-black text-slate-900 mb-2">Kelola Banner Promo</h1>
            <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
        </div>
        <a href="/admin/banners/new" 
            class="bg-indigo-600 text-white px-6 py-3 rounded-2xl font-bold flex items-center gap-2 hover:bg-slate-900 transition shadow-lg shadow-indigo-100">
            <i data-lucide="plus-circle" class="w-5 h-5"></i> Tambah Banner
        </a>
    </div>

    <!-- Banner Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <% Banner.all.each do |banner| %>
            <div class="glass rounded-[40px] overflow-hidden border border-white/60 shadow-xl group relative">
                <div class="absolute top-4 right-4 z-10 flex gap-2">
                    <form action="/admin/banners/delete" method="POST" onsubmit="return confirm('Hapus banner ini?')">
                        <input type="hidden" name="id" value="<%= banner.id %>">
                        <button type="submit" class="w-10 h-10 bg-red-500 text-white rounded-full flex items-center justify-center hover:bg-slate-900 transition shadow-lg">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                    </form>
                </div>

                <div class="aspect-[21/9] bg-slate-100 relative">
                    <img src="<%= banner.image_url %>" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent flex flex-col justify-end p-8">
                        <h3 class="text-2xl font-black text-white mb-1"><%= banner.title %></h3>
                        <p class="text-indigo-300 font-bold mb-4 tracking-wide"><%= banner.subtitle %></p>
                        <div class="flex items-center gap-4">
                            <span class="<%= banner.active ? 'bg-emerald-500' : 'bg-slate-500' %> text-white text-[10px] font-black uppercase px-3 py-1 rounded-full tracking-tighter">
                                <%= banner.active ? 'Aktif' : 'Nonaktif' %>
                            </span>
                            <span class="text-xs font-bold text-white/60">Link: <%= banner.link %></span>
                        </div>
                    </div>
                </div>
            </div>
        <% end %>
        
        <% if Banner.all.empty? %>
            <div class="col-span-full py-20 text-center glass rounded-[40px] border border-white/60">
                <i data-lucide="image" class="w-16 h-16 text-slate-300 mx-auto mb-4"></i>
                <p class="text-slate-500 font-medium">Belum ada banner promo yang ditambahkan.</p>
            </div>
        <% end %>
    </div>
</div>
