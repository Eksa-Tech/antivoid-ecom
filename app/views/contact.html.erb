<div class="max-w-7xl mx-auto px-6 py-20 animate__animated animate__fadeIn">
    <div class="text-center mb-16">
        <span class="inline-block px-4 py-1.5 rounded-full glass bg-indigo-50 text-indigo-600 text-sm font-bold mb-6 border border-indigo-100 uppercase tracking-widest">Hubungi Kami</span>
        <h1 class="text-5xl md:text-7xl font-extrabold text-slate-900 leading-tight mb-8">
            Ada Pertanyaan? <br/>
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">Kami Siap Membantu</span>
        </h1>
        <div class="h-2 w-32 bg-indigo-600 rounded-full mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-4 space-y-6">
            <div class="glass p-8 rounded-[40px] border border-white/60 shadow-lg group hover-lift transition-all">
                <div class="w-14 h-14 bg-indigo-600 text-white rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-indigo-100 group-hover:rotate-12 transition">
                    <i data-lucide="mail" class="w-8 h-8"></i>
                </div>
                <h3 class="text-xl font-black text-slate-900 mb-2">Email Support</h3>
                <p class="text-slate-500">support@antivoid.id</p>
                <p class="text-xs text-slate-400 mt-4 uppercase font-bold tracking-widest">Respon dalam 24 Jam</p>
            </div>

            <div class="glass p-8 rounded-[40px] border border-white/60 shadow-lg group hover-lift transition-all">
                <div class="w-14 h-14 bg-emerald-500 text-white rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-emerald-100 group-hover:rotate-12 transition">
                    <i data-lucide="phone" class="w-8 h-8"></i>
                </div>
                <h3 class="text-xl font-black text-slate-900 mb-2">WhatsApp</h3>
                <p class="text-slate-500">+<%= ENV['WHATSAPP_NUMBER'] || '6281234567890' %></p>
                <p class="text-xs text-slate-400 mt-4 uppercase font-bold tracking-widest">Senin - Minggu, 09:00 - 21:00</p>
            </div>

            <div class="glass p-8 rounded-[40px] border border-white/60 shadow-lg group hover-lift transition-all">
                <div class="w-14 h-14 bg-slate-900 text-white rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-slate-100 group-hover:rotate-12 transition">
                    <i data-lucide="map-pin" class="w-8 h-8"></i>
                </div>
                <h3 class="text-xl font-black text-slate-900 mb-2">Kantor Pusat</h3>
                <p class="text-slate-500">Sudirman Central Business District, Jakarta</p>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-8">
            <div class="glass p-10 md:p-16 rounded-[60px] border border-white/60 shadow-2xl relative overflow-hidden">
                <div class="absolute -top-20 -right-20 w-80 h-80 bg-indigo-600/10 blur-[120px] rounded-full"></div>
                
                <form class="space-y-8 relative z-10" id="contactForm" onsubmit="sendToWhatsApp(event)">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block text-xs font-black text-slate-500 mb-3 ml-1 uppercase tracking-widest">Nama Lengkap</label>
                            <input type="text" id="waName" placeholder="Masukkan nama Anda" required
                                class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 outline-none transition shadow-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-black text-slate-500 mb-3 ml-1 uppercase tracking-widest">Alamat Email</label>
                            <input type="email" id="waEmail" placeholder="email@contoh.com" required
                                class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 outline-none transition shadow-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-500 mb-3 ml-1 uppercase tracking-widest">Subjek Pesan</label>
                        <select id="waSubject" required class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 outline-none transition shadow-sm appearance-none">
                            <option>Pertanyaan Produk</option>
                            <option>Status Pengiriman</option>
                            <option>Keluhan & Saran</option>
                            <option>Partnership</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-500 mb-3 ml-1 uppercase tracking-widest">Pesan Anda</label>
                        <textarea id="waMessage" rows="5" required placeholder="Tuliskan detail pertanyaan Anda di sini..."
                            class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 outline-none transition shadow-sm"></textarea>
                    </div>
                    
                    <button type="submit" 
                        class="w-full bg-emerald-500 text-white py-6 rounded-3xl font-black text-xl shadow-2xl shadow-emerald-100 hover:bg-emerald-600 hover:shadow-none transition-all flex items-center justify-center gap-4 group">
                        Kirim via WhatsApp <i data-lucide="message-circle" class="w-6 h-6 group-hover:scale-110 transition"></i>
                    </button>
                </form>

                <script>
                    function sendToWhatsApp(e) {
                        e.preventDefault();
                        const name = document.getElementById('waName').value;
                        const email = document.getElementById('waEmail').value;
                        const subject = document.getElementById('waSubject').value;
                        const message = document.getElementById('waMessage').value;
                        
                        const text = `Halo Antivoid Shop!\n\n*Nama:* ${name}\n*Email:* ${email}\n*Subjek:* ${subject}\n\n*Pesan:*\n${message}`;
                        const encodedText = encodeURIComponent(text);
                        
                        // Nomor WhatsApp tujuan
                        const whatsappNumber = '<%= ENV['WHATSAPP_NUMBER'] || '6281234567890' %>';
                        const url = `https://wa.me/${whatsappNumber}?text=${encodedText}`;
                        
                        // Buka WhatsApp di tab baru
                        window.open(url, '_blank');
                        
                        // Kosongkan seluruh form kembali
                        document.getElementById('contactForm').reset();
                    }
                </script>
            </div>
        </div>
    </div>
</div>
