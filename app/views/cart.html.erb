<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <div class="mb-10">
        <h1 class="text-4xl font-black text-slate-900 mb-2 flex items-center gap-3">
            <i data-lucide="shopping-cart" class="w-10 h-10 text-indigo-600"></i> Keranjang Belanja
        </h1>
        <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
    </div>

    <% cart = @req.session['cart'] || {} %>
    <% if cart.empty? %>
        <div class="glass rounded-[40px] py-32 text-center animate__animated animate__zoomIn border border-white/60">
            <div class="bg-slate-100 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-8 text-slate-400">
                <i data-lucide="shopping-basket" class="w-12 h-12"></i>
            </div>
            <h3 class="text-3xl font-black text-slate-800 mb-4">Keranjang Kosong</h3>
            <p class="text-slate-500 mb-10 text-lg">Sepertinya Anda belum memilih produk impian Anda.</p>
            <a href="/shop" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-10 py-4 rounded-2xl font-bold text-lg shadow-xl shadow-indigo-100 hover:bg-slate-900 transition">
                <i data-lucide="arrow-left" class="w-5 h-5"></i> Mulai Belanja
            </a>
        </div>
    <% else %>
        <div class="lg:grid lg:grid-cols-12 lg:gap-x-12 lg:items-start">
            <div class="lg:col-span-8 space-y-6">
                <% total = 0 %>
                <% cart.each_with_index do |(id, qty), index| %>
                    <% product = Product.find(id) %>
                    <% next unless product %>
                    <% subtotal = product.price * qty %>
                    <% total += subtotal %>
                    <div class="glass p-6 rounded-[32px] border border-white/60 flex flex-col sm:flex-row items-center gap-6 animate__animated animate__fadeInUp cart-item" 
                         data-product-id="<%= product.id %>" 
                         data-price="<%= product.price %>"
                         style="animation-delay: <%= index * 0.1 %>s">
                        <div class="w-32 h-32 bg-slate-100 rounded-2xl overflow-hidden shadow-inner border border-white/40">
                            <img src="<%= product.image_url || 'https://via.placeholder.com/200' %>" 
                                alt="<%= product.name %>" 
                                class="w-full h-full object-center object-cover">
                        </div>

                        <div class="flex-grow text-center sm:text-left">
                            <h3 class="text-xl font-bold text-slate-900 mb-1"><a href="/product?id=<%= product.id %>" class="hover:text-indigo-600 transition"><%= product.name %></a></h3>
                            <p class="text-sm text-slate-400 font-medium mb-4"><%= ViewHelper.format_rupiah(product.price) %> / unit</p>
                            
                            <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                                <div class="glass border border-white/40 p-1 rounded-xl flex items-center">
                                    <button type="button" onclick="updateQuantity('<%= product.id %>', -1)" 
                                        class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600"><i data-lucide="minus" class="w-4 h-4"></i></button>
                                    <input type="number" id="qty-<%= product.id %>" value="<%= qty %>" min="1" max="<%= product.stock %>"
                                        onchange="updateQuantity('<%= product.id %>', 0)" 
                                        class="w-12 bg-transparent text-center font-bold outline-none">
                                    <button type="button" onclick="updateQuantity('<%= product.id %>', 1)" 
                                        class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600"><i data-lucide="plus" class="w-4 h-4"></i></button>
                                </div>
                                
                                <div class="flex items-center gap-6">
                                    <p class="text-2xl font-black text-slate-900 item-subtotal" id="subtotal-<%= product.id %>"><%= ViewHelper.format_rupiah(subtotal) %></p>
                                    <a href="/cart/remove?id=<%= product.id %>" class="bg-red-50 text-red-500 p-2 rounded-xl hover:bg-red-500 hover:text-white transition shadow-sm">
                                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% end %>
            </div>

            <div class="mt-16 lg:mt-0 lg:col-span-4 sticky top-24">
                <div class="glass p-8 rounded-[40px] border border-white/60 shadow-xl overflow-hidden">
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-600/10 blur-3xl rounded-full"></div>
                    <h2 class="text-2xl font-black text-slate-900 mb-8 flex items-center gap-2">
                         <i data-lucide="receipt" class="w-6 h-6 text-indigo-600"></i> Ringkasan
                    </h2>
                    
                    <div class="space-y-6">
                        <div class="flex items-center justify-between text-slate-500">
                             <span class="font-medium">Subtotal</span>
                             <span class="font-bold text-slate-900 cart-grand-total"><%= ViewHelper.format_rupiah(total) %></span>
                        </div>
                        <div class="flex items-center justify-between text-slate-500">
                             <span class="font-medium">Pengiriman</span>
                             <span class="font-bold text-green-600">GRATIS</span>
                        </div>
                        <div class="h-px bg-slate-200/60 my-6"></div>
                        <div class="flex items-center justify-between">
                             <span class="text-lg font-bold text-slate-900">Total Akhir</span>
                             <span class="text-3xl font-black text-indigo-600 cart-grand-total"><%= ViewHelper.format_rupiah(total) %></span>
                        </div>
                    </div>

                    <div class="mt-10">
                        <a href="/checkout" class="w-full bg-slate-900 text-white py-5 rounded-2xl font-bold text-xl shadow-xl shadow-slate-200 hover:bg-indigo-600 transition flex items-center justify-center gap-3">
                            Lanjut ke Pembayaran <i data-lucide="arrow-right" class="w-6 h-6"></i>
                        </a>
                    </div>
                    
                    <div class="mt-8 flex items-center justify-center gap-4 py-4 opacity-40">
                         <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" class="h-6">
                         <img src="https://upload.wikimedia.org/wikipedia/commons/5/5c/Visa_Inc._logo_%282021–present%29.svg" class="h-4">
                         <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" class="h-4">
                    </div>
                </div>
            </div>
        </div>

        <script>
            function formatRupiah(number) {
                return "Rp " + Math.round(number).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
            }

            function updateQuantity(productId, delta) {
                const input = document.getElementById('qty-' + productId);
                const itemRow = input.closest('.cart-item');
                const price = parseFloat(itemRow.dataset.price);
                const subtotalEl = document.getElementById('subtotal-' + productId);
                
                let newQty = parseInt(input.value) + delta;
                if (delta === 0) newQty = parseInt(input.value); // manual change
                
                if (newQty < 1) return;
                if (newQty > parseInt(input.max)) return;

                input.value = newQty;
                
                // Update item subtotal
                const newSubtotal = newQty * price;
                subtotalEl.innerText = formatRupiah(newSubtotal);

                // Update grand total
                updateGrandTotal();

                // Send to server
                const formData = new FormData();
                formData.append('product_id', productId);
                formData.append('quantity', newQty);

                fetch('/cart/update', {
                    method: 'POST',
                    body: formData
                });
            }

            function updateGrandTotal() {
                let total = 0;
                document.querySelectorAll('.cart-item').forEach(item => {
                    const price = parseFloat(item.dataset.price);
                    const qty = parseInt(item.querySelector('input[type="number"]').value);
                    total += price * qty;
                });

                document.querySelectorAll('.cart-grand-total').forEach(el => {
                    el.innerText = formatRupiah(total);
                });
            }
        </script>
    <% end %>
</div>
